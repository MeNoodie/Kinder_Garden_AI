# Ignore everything by default
*

# Allow .gitignore and README.md
!.gitignore
!README.md

# Allow entire frontend directory
!frontend/
!frontend/**
frontend/.next/
frontend/node_modules/
frontend/*.log

# Allow specific backend subdirectories
!backend/
!backend/auth/
!backend/auth/**
!backend/prompts/
!backend/prompts/**
!backend/utils/
!backend/utils/**
!backend/services/
!backend/services/**
!backend/config/
!backend/config/**
!backend/routes/
!backend/routes/**
!backend/api/
!backend/api/**

# Ignore pycache inside allowed directories
**/__pycache__/
*.py[oc]

/backend/tools
